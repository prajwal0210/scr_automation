# =========================
# Generated / runtime data
# =========================
output/*
logs/*
ran_already/*

# =========================
# Raw / sensitive data
# =========================
input/*
raw_files/*
reference/*

# =========================
# 🔥 IMPORTANT FIX
# Allow folders first
# =========================
!output/
!logs/
!ran_already/
!input/
!raw_files/
!reference/

# =========================
# Then allow .gitkeep
# =========================
!output/.gitkeep
!logs/.gitkeep
!ran_already/.gitkeep
!input/.gitkeep
!raw_files/.gitkeep
!reference/.gitkeep